# Пример переменных окружения blxck.hub.
# Скопировать в .env и заполнить реальными значениями (.env в .gitignore).
# Локально без .env проект работает на SQLite + in-memory channel layer.

# --- Django ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=blxckhub.server34.netcraze.club,localhost,127.0.0.1

# --- База данных (продакшен — PostgreSQL; без переменной — SQLite) ---
DATABASE_URL=postgres://blxckhub:blxckhub@rgz-db:5432/blxckhub
POSTGRES_DB=blxckhub
POSTGRES_USER=blxckhub
POSTGRES_PASSWORD=replace-with-db-password

# --- Redis (channel layer; без переменной — in-memory) ---
REDIS_URL=redis://rgz-redis:6379/0

# --- CORS (origin фронтенда) ---
CORS_ALLOWED_ORIGINS=https://blxckhub.server34.netcraze.club

# --- Медиа и загрузки ---
MEDIA_ROOT=/srv/media
MAX_UPLOAD_SIZE=209715200

# --- Фронтенд (Vite, на этапе сборки) ---
# Пусто = относительные пути (тот же origin за Caddy).
VITE_API_BASE=
VITE_WS_BASE=
